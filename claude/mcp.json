{
    "mcpServers": {
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "neovim": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-neovim-server"
            ],
            "env": {
                "ALLOW_SHELL_COMMANDS": "true",
                "NVIM_SOCKET_PATH": "/tmp/nvim"
            }
        }
    }
}
